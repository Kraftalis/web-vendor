// Kraftalis — Authentication Database Schema
// Designed for NextAuth.js + Prisma Adapter
// Best practices: UUID PKs, audit timestamps, soft delete, indexes, enums

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum AuthProvider {
  CREDENTIALS
  GOOGLE
}

// ─── NextAuth Required Models ───────────────────────────────────────────────

/// Core user model — stores identity and profile info.
/// Linked to accounts, sessions, and audit logs.
model User {
  id            String     @id @default(uuid()) @db.Uuid
  name          String?    @db.VarChar(255)
  email         String     @unique @db.VarChar(320)
  emailVerified DateTime?  @map("email_verified")
  image         String?    @db.Text
  passwordHash  String?    @map("password_hash") @db.Text
  role          UserRole   @default(USER)
  status        UserStatus @default(ACTIVE)

  // Audit fields
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  accounts     Account[]
  sessions     Session[]
  auditLogs    AuditLog[]
  businessProfile BusinessProfile?
  pushSubscriptions PushSubscription[]

  @@index([email])
  @@index([status])
  @@index([role])
  @@index([createdAt])
  @@map("users")
}

/// OAuth accounts linked to users (Google, etc.)
/// One user can have multiple linked accounts.
model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String  @db.VarChar(50)
  provider          String  @db.VarChar(50)
  providerAccountId String  @map("provider_account_id") @db.VarChar(255)
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String? @db.VarChar(50)
  scope             String? @db.Text
  id_token          String? @db.Text
  session_state     String? @db.Text

  // Audit fields
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

/// Server-side sessions for database strategy (optional but recommended).
model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token") @db.Text
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime @db.Timestamptz

  // Audit fields
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
  @@map("sessions")
}

/// Email verification tokens (passwordless, email confirm).
model VerificationToken {
  identifier String   @db.VarChar(320)
  token      String   @unique @db.Text
  expires    DateTime @db.Timestamptz

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Extended Auth Models ───────────────────────────────────────────────────

/// Email verification tokens sent during credentials sign-up.
model EmailVerificationToken {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @db.VarChar(320)
  token     String   @unique @db.Text
  expires   DateTime @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([email])
  @@index([token])
  @@map("email_verification_tokens")
}

/// Tracks password reset requests with expiry and usage status.
model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @db.VarChar(320)
  token     String   @unique @db.Text
  expires   DateTime @db.Timestamptz
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([email])
  @@index([token])
  @@map("password_reset_tokens")
}

/// Audit log for all authentication-related events.
/// Immutable — never updated or deleted. Used for security tracing.
model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String   @db.VarChar(100) // e.g. "LOGIN_SUCCESS", "LOGIN_FAILED", "LOGOUT", "PASSWORD_RESET"
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.Text
  metadata  Json?    @db.JsonB // Flexible extra data
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Event Management Models ────────────────────────────────────────────────

enum EventStatus {
  INQUIRY
  WAITING_CONFIRMATION
  BOOKED
  ONGOING
  COMPLETED
}

enum PaymentStatus {
  UNPAID
  DP_PAID
  PAID
}

enum PaymentType {
  DOWN_PAYMENT
  FULL_PAYMENT
  INSTALLMENT
}

// ─── Event Category (Per-Vendor) ────────────────────────────────────────────

/// Global event categories (master data).
/// e.g. "Wedding", "Engagement", "Birthday", "Corporate"
/// Used in event forms instead of hardcoded event types.
model EventCategory {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(255)
  description String?  @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")

  // Audit fields
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  packages    Package[]
  events      Event[]

  @@index([sortOrder])
  @@index([isActive])
  @@map("event_categories")
}

// ─── Package Category (Master Data) ─────────────────────────────────────────

/// Package categories for organizing vendor service packages.
/// e.g. "Photography", "Videography", "MUA", "Decoration", "Catering", "WO"
/// Each vendor's packages can be assigned to a category for filtering.
model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(255) // e.g. "Photography"
  description String?  @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")

  // Audit fields
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  packages      Package[]

  @@index([sortOrder])
  @@index([isActive])
  @@map("categories")
}

// ─── Package & Pricing ──────────────────────────────────────────────────────

/// Vendor-defined service packages.
/// Generic enough for photographers, WO, catering, MUA, decoration, etc.
/// A package can have zero or more PackageItem variations.
/// - 0 variations: the package `price` is the single flat price.
/// - 1+ variations: client must pick a variation; each variation has its own price.
model Package {
  id             String  @id @default(uuid()) @db.Uuid
  businessProfileId String @map("business_profile_id") @db.Uuid
  categoryId     String? @map("category_id") @db.Uuid
  eventCategoryId String? @map("event_category_id") @db.Uuid
  name           String  @db.VarChar(255) // e.g. "Paket Wisuda Photoshoot"
  description    String? @db.Text // Free-text summary shown to clients

  // Base / fallback price — used when there are no variations.
  // When variations exist, this can be set to 0 or the min variation price.
  price       Decimal @db.Decimal(12, 2)
  currency    String  @default("IDR") @db.VarChar(10)

  // Active flag — vendor can archive packages without deleting
  isActive    Boolean @default(true) @map("is_active")
  sortOrder   Int     @default(0) @map("sort_order")

  // Newline-separated inclusions stored as text array
  inclusions  String[] @default([])

  // Audit fields
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  businessProfile BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  category      Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  eventCategory  EventCategory? @relation(fields: [eventCategoryId], references: [id], onDelete: SetNull)
  items         PackageItem[]

  @@index([businessProfileId])
  @@index([categoryId])
  @@index([eventCategoryId])
  @@index([isActive])
  @@index([sortOrder])
  @@map("packages")
}

/// Price variations within a package.
/// Each variation represents a distinct pricing tier / configuration.
/// Generic enough for any vendor type:
///   - Photography: "2 Orang – 1 Jam", "3 Orang – 1.5 Jam"
///   - MUA: "Pengantin", "Pengantin + Pagar Ayu"
///   - Catering: "100 Pax", "150 Pax"
///   - Decoration: "Basic", "Premium", "Mewah"
/// If a package has only one variation, clients skip the selection step.
model PackageItem {
  id          String   @id @default(uuid()) @db.Uuid
  packageId   String   @map("package_id") @db.Uuid
  label       String   @db.VarChar(255)   // Short name shown to client, e.g. "2 Orang – 1 Jam"
  description String?  @db.Text           // Optional detail: inclusions, notes, etc.
  price       Decimal  @db.Decimal(12, 2) // Price for this specific variation
  sortOrder   Int      @default(0) @map("sort_order")

  // Per-variation inclusions (what this tier includes)
  inclusions  String[] @default([])

  // Relations
  package     Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
  @@map("package_items")
}

/// Vendor-defined add-ons that can be added to any booking.
/// e.g. "Extra 1 jam @250rb", "Photo booth", "Dekorasi tambahan"
model AddOn {
  id          String  @id @default(uuid()) @db.Uuid
  businessProfileId String @map("business_profile_id") @db.Uuid
  name        String  @db.VarChar(255) // e.g. "Tambahan 1 jam"
  description String? @db.Text
  price       Decimal @db.Decimal(12, 2)
  currency    String  @default("IDR") @db.VarChar(10)
  isActive    Boolean @default(true) @map("is_active")
  sortOrder   Int     @default(0) @map("sort_order")

  // Audit fields
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  businessProfile BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@index([businessProfileId])
  @@index([isActive])
  @@map("add_ons")
}

// ─── Events ─────────────────────────────────────────────────────────────────

/// Events / bookings managed by vendors.
/// Uses snapshot pattern (marketplace-style): package & add-on data are copied
/// at "checkout" time so later changes to the master data don't affect this record.
model Event {
  id            String        @id @default(uuid()) @db.Uuid
  businessProfileId String    @map("business_profile_id") @db.Uuid

  // Client info
  clientName    String        @map("client_name") @db.VarChar(255)
  clientPhone   String        @map("client_phone") @db.VarChar(50)
  clientPhoneSecondary String? @map("client_phone_secondary") @db.VarChar(50)
  clientEmail   String?       @map("client_email") @db.VarChar(320)

  // Event details
  eventType     String        @map("event_type") @db.VarChar(100)
  eventCategoryId String?     @map("event_category_id") @db.Uuid
  eventDate     DateTime      @map("event_date") @db.Date
  eventTime     String?       @map("event_time") @db.VarChar(20)
  eventLocation String?       @map("event_location") @db.Text
  eventLocationUrl String?    @map("event_location_url") @db.Text

  // Snapshot data — independent of master Package/AddOn tables
  // JSON: { name, description, price, currency, variationLabel, inclusions[] }
  packageSnapshot Json?       @map("package_snapshot") @db.JsonB
  // JSON: [{ name, description, price, currency, quantity }]
  addOnsSnapshot  Json?       @map("add_ons_snapshot") @db.JsonB

  // Pricing (total calculated from snapshot)
  amount        Decimal?      @db.Decimal(12, 2)
  currency      String        @default("IDR") @db.VarChar(10)

  // Status
  eventStatus   EventStatus   @default(INQUIRY) @map("event_status")
  paymentStatus PaymentStatus @default(UNPAID) @map("payment_status")

  // Notes
  notes         String?       @db.Text

  // Audit fields
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  businessProfile BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  eventCategory   EventCategory?  @relation(fields: [eventCategoryId], references: [id], onDelete: SetNull)
  bookingLink   BookingLink?
  payments      Payment[]
  briefs        EventBrief[]
  financeTransactions FinanceTransaction[]

  @@index([businessProfileId])
  @@index([eventStatus])
  @@index([paymentStatus])
  @@index([eventDate])
  @@index([eventCategoryId])
  @@index([createdAt])
  @@map("events")
}

// ─── Event Brief (Notes / Instructions) ─────────────────────────────────────

/// Briefs are notes, instructions, or file attachments posted to an event.
/// Both vendors and clients can post briefs (tracked via authorType).
model EventBrief {
  id            String   @id @default(uuid()) @db.Uuid
  eventId       String   @map("event_id") @db.Uuid

  // Content
  title         String   @db.VarChar(500)
  content       String?  @db.Text          // HTML from rich text editor
  attachments   Json     @default("[]") @db.JsonB
  // JSON: [{ name, url, type, size }]

  // Author tracking
  authorType    String   @map("author_type") @db.VarChar(10) // "VENDOR" or "CLIENT"
  authorName    String?  @map("author_name") @db.VarChar(255)

  // Audit fields
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([createdAt])
  @@map("event_briefs")
}

// ─── Booking Link (Persistent Client Portal) ───────────────────────────────

/// Unique booking links generated by vendors.
/// Contains the full offer snapshot so the client sees exactly what the vendor configured.
/// Once event is created (client fills remaining fields), snapshot moves to Event.
model BookingLink {
  id        String    @id @default(uuid()) @db.Uuid
  businessProfileId String @map("business_profile_id") @db.Uuid
  token     String    @unique @db.VarChar(64)
  eventId   String?   @unique @map("event_id") @db.Uuid // 1:1 with event

  // Pre-filled by vendor
  clientName    String?   @map("client_name") @db.VarChar(255)
  clientPhone   String?   @map("client_phone") @db.VarChar(50)
  clientPhoneSecondary String? @map("client_phone_secondary") @db.VarChar(50)
  eventCategoryId String? @map("event_category_id") @db.Uuid
  eventDate     DateTime? @map("event_date") @db.Date
  eventTime     String?   @map("event_time") @db.VarChar(20)
  eventLocation String?   @map("event_location") @db.Text
  eventLocationUrl String? @map("event_location_url") @db.Text

  // Snapshot of offered package & add-ons (marketplace pattern)
  packageSnapshot Json?   @map("package_snapshot") @db.JsonB
  addOnsSnapshot  Json?   @map("add_ons_snapshot") @db.JsonB
  totalAmount     Decimal? @map("total_amount") @db.Decimal(12, 2)

  // Expiry for the initial booking form (not the tracking portal)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz

  // Audit fields
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  businessProfile BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  event     Event?    @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([token])
  @@index([businessProfileId])
  @@map("booking_links")
}

// ─── Payment Records ────────────────────────────────────────────────────────

/// Payment records for an event — tracks DP, installments, final payment.
/// Clients can upload receipt images via their booking link.
model Payment {
  id           String      @id @default(uuid()) @db.Uuid
  eventId      String      @map("event_id") @db.Uuid
  paymentType  PaymentType @map("payment_type")
  amount       Decimal     @db.Decimal(12, 2)
  currency     String      @default("IDR") @db.VarChar(10)
  note         String?     @db.Text
  receiptUrl   String?     @map("receipt_url") @db.Text // URL to uploaded receipt image
  receiptName  String?     @map("receipt_name") @db.VarChar(255) // Original filename
  isVerified   Boolean     @default(false) @map("is_verified") // Vendor confirms receipt
  paidBy       String      @default("CLIENT") @map("paid_by") @db.VarChar(10) // "CLIENT" or "VENDOR"
  paidAt       DateTime    @default(now()) @map("paid_at") @db.Timestamptz

  // Audit fields
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  event        Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([paidAt])
  @@map("payments")
}

// ─── Business Profile ───────────────────────────────────────────────────────

/// Vendor business profile — the central business entity.
/// Owns events, packages, add-ons, and booking links.
/// One user has one business profile (for now).
model BusinessProfile {
  id          String  @id @default(uuid()) @db.Uuid
  userId      String  @unique @map("user_id") @db.Uuid

  // Branding
  businessName String  @map("business_name") @db.VarChar(255)
  tagline      String? @db.VarChar(500)
  logoUrl      String? @map("logo_url") @db.Text

  // Contact
  email        String? @db.VarChar(320)
  phoneNumber  String? @map("phone_number") @db.VarChar(50)

  // Social media links — stored as JSON for flexibility
  // { instagram?: string, tiktok?: string, facebook?: string, linkedin?: string, whatsapp?: string, ...}
  socialLinks  Json?   @map("social_links") @db.JsonB

  // Audit fields
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)
  events       Event[]
  bookingLinks BookingLink[]
  packages     Package[]
  addOns       AddOn[]
  financeAccounts    FinanceAccount[]
  financeTransactions FinanceTransaction[]

  @@index([userId])
  @@map("business_profiles")
}

// ─── Push Notification Subscriptions ────────────────────────────────────────

/// Stores Web Push API subscriptions for each user device.
/// A user can have multiple subscriptions (phone, desktop, etc.)
model PushSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  endpoint  String   @unique @db.Text
  p256dh    String   @db.Text  // Public key
  auth      String   @db.Text  // Auth secret
  userAgent String?  @map("user_agent") @db.Text

  // Audit fields
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// ─── Finance / Bookkeeping ──────────────────────────────────────────────────

enum TransactionType {
  INCOME
  EXPENSE
}

/// Finance account — represents a wallet, bank account, or asset category.
/// Vendors can track balances across multiple accounts.
/// e.g. "BCA", "Cash", "Equipment", "Marketing"
model FinanceAccount {
  id                String  @id @default(uuid()) @db.Uuid
  businessProfileId String  @map("business_profile_id") @db.Uuid
  name              String  @db.VarChar(255) // e.g. "BCA", "Cash", "Equipment"
  description       String? @db.Text
  isPrimary         Boolean @default(false) @map("is_primary") // Primary account receives auto-income from bookings
  sortOrder         Int     @default(0) @map("sort_order")
  isActive          Boolean @default(true) @map("is_active")

  // Audit fields
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  businessProfile BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  transactions    FinanceTransaction[]

  @@index([businessProfileId])
  @@map("finance_accounts")
}

/// Finance transaction — individual income or expense entry.
/// Can optionally link to an Event (e.g. "Payment from Client X for Event Y").
/// eventId link enables automatic revenue tracking from event payments.
model FinanceTransaction {
  id                String          @id @default(uuid()) @db.Uuid
  businessProfileId String          @map("business_profile_id") @db.Uuid
  accountId         String          @map("account_id") @db.Uuid
  type              TransactionType // INCOME or EXPENSE
  category          String          @db.VarChar(100) // e.g. "Event Payment", "Equipment", "Transport", "Marketing"
  description       String?         @db.Text
  amount            Decimal         @db.Decimal(14, 2)
  currency          String          @default("IDR") @db.VarChar(10)
  transactionDate   DateTime        @map("transaction_date") @db.Date
  receiptUrl        String?         @map("receipt_url") @db.Text
  receiptName       String?         @map("receipt_name") @db.VarChar(255)

  // Optional link to an event (for revenue from bookings)
  eventId           String?         @map("event_id") @db.Uuid

  // Tags for flexible categorization (e.g. ["tax-deductible", "Q1"])
  tags              String[]        @default([])

  // Notes
  notes             String?         @db.Text

  // Audit fields
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  account           FinanceAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  event             Event?          @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([businessProfileId])
  @@index([accountId])
  @@index([type])
  @@index([transactionDate])
  @@index([category])
  @@index([eventId])
  @@map("finance_transactions")
}
